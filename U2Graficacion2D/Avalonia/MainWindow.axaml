<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tabs="clr-namespace:U2Graficacion2D.Tabs"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="U2Graficacion2D.MainWindow"
        Title="U2 Graficacion 2D (Avalonia)"
        Background="#2D2D2D"
        Foreground="#FFFFFF">
    <TabControl Name="MainTabControl" Background="#2D2D2D" Foreground="#FFFFFF">
        <!-- Tabs will be added via code-behind or here -->
    </TabControl>
</Window>
