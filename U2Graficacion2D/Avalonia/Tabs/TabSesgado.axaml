<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:U2Graficacion2D"
             x:Class="U2Graficacion2D.Tabs.TabSesgado"
             Background="#3D3D3D"
             Foreground="#FFFFFF">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom" Height="120" Background="#2D2D2D" BorderBrush="#555555" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Vertical" Margin="15" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="shx:" VerticalAlignment="Center" Width="30" Foreground="#FFFFFF"/>
                    <Slider Name="SliderShx" Minimum="-1" Maximum="1" Value="0.3" Width="250" Foreground="#00D4FF"
                            PropertyChanged="Slider_PropertyChanged"/>
                    <TextBlock Text="{Binding #SliderShx.Value, StringFormat={}{0:F2}}" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="shy:" VerticalAlignment="Center" Width="30" Foreground="#FFFFFF"/>
                    <Slider Name="SliderShy" Minimum="-1" Maximum="1" Value="0.2" Width="250" Foreground="#00D4FF"
                            PropertyChanged="Slider_PropertyChanged"/>
                    <TextBlock Text="{Binding #SliderShy.Value, StringFormat={}{0:F2}}" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                </StackPanel>
                <TextBlock Name="LblInfo" FontFamily="Consolas" FontSize="11" Foreground="#CCCCCC"/>
            </StackPanel>
        </Border>
        
        <local:DrawingCanvas Name="MainCanvas" Background="#1a1a1a" Paint="OnPaint"/>
    </DockPanel>
</UserControl>
