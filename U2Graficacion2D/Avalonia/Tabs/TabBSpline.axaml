<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:U2Graficacion2D"
             x:Class="U2Graficacion2D.Tabs.TabBSpline"
             Background="#3D3D3D"
             Foreground="#FFFFFF">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom" Height="100" Background="#2D2D2D" BorderBrush="#555555" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Vertical" Margin="15" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Grado:" VerticalAlignment="Center" Width="50" Foreground="#FFFFFF"/>
                    <Slider Name="SliderGrado" Minimum="2" Maximum="4" Value="3" Width="200" PropertyChanged="Slider_PropertyChanged"/>
                    <TextBlock Text="{Binding #SliderGrado.Value, StringFormat={}{0:0}}" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                </StackPanel>
                <TextBlock Name="LblInfo" FontFamily="Consolas" FontSize="10" Foreground="#CCCCCC"/>
            </StackPanel>
        </Border>
        
        <local:DrawingCanvas Name="MainCanvas" Background="#1a1a1a" Paint="OnPaint"/>
    </DockPanel>
</UserControl>
